-static void greetd_start_session(const char *exec) {
+static char *strip_desktop_exec_field_codes(const char *exec) {
+    GString *out = g_string_new(NULL);
+    for (const char *p = exec; p && *p; p++) {
+        if (*p == '%' && p[1]) {
+            if (p[1] == '%') {
+                g_string_append_c(out, '%');
+                p++;
+                continue;
+            }
+            if (strchr("fFuUick", p[1])) {
+                p++;
+                continue;
+            }
+        }
+        g_string_append_c(out, *p);
+    }
+    return g_string_free(out, FALSE);
+}
+
+static void desktop_names_to_current(const char *desktop_names, const char *fallback,
+                                     char *out, size_t out_sz) {
+    const char *src = (desktop_names && desktop_names[0]) ? desktop_names : fallback;
+    if (!src || !src[0]) src = "unknown";
+
+    size_t oi = 0;
+    bool last_sep = false;
+    for (const char *p = src; *p && oi + 1 < out_sz; p++) {
+        if (*p == ';') {
+            if (oi > 0 && !last_sep && oi + 1 < out_sz) {
+                out[oi++] = ':';
+                last_sep = true;
+            }
+        } else {
+            out[oi++] = *p;
+            last_sep = false;
+        }
+    }
+    while (oi > 0 && out[oi - 1] == ':') oi--;
+    out[oi] = '\0';
+    if (!out[0]) snprintf(out, out_sz, "%s", fallback && fallback[0] ? fallback : "unknown");
+}
+
+static void greetd_add_env(JsonBuilder *b, const char *key, const char *value) {
+    char item[1024];
+    snprintf(item, sizeof item, "%s=%s", key, value ? value : "");
+    json_builder_add_string_value(b, item);
+}
+
+static void greetd_add_session_env(JsonBuilder *b, const struct g_session *session) {
+    json_builder_set_member_name(b, "env");
+    json_builder_begin_array(b);
+    /*
+     * greetd injects start_session.env into PAM before pam_systemd opens the
+     * session. These values must be here, not only in the launcher process.
+     */
+    greetd_add_env(b, "XDG_SESSION_TYPE", "wayland");
+    greetd_add_env(b, "XDG_SESSION_CLASS", "user");
+    greetd_add_env(b, "XDG_SESSION_DESKTOP", session->session_id);
+    greetd_add_env(b, "XDG_CURRENT_DESKTOP", session->current_desktop);
+    greetd_add_env(b, "DESKTOP_SESSION", session->session_id);
+    greetd_add_env(b, "GDK_BACKEND", "wayland");
+    json_builder_end_array(b);
+}
+
+static void greetd_start_session(const struct g_session *session) {
     JsonBuilder *b = json_builder_new();
     json_builder_begin_object(b);
     json_builder_set_member_name(b, "type"); json_builder_add_string_value(b, "start_session");
