-    g_free(copy);
+
+    const char *launcher = getenv("SINGULARITY_GREETER_SESSION_LAUNCHER");
+    if (launcher && launcher[0] && session->desktop_file[0]) {
+        char *quoted_launcher = g_shell_quote(launcher);
+        char *quoted_desktop_file = g_shell_quote(session->desktop_file);
+        char *cmd = g_strdup_printf("%s %s", quoted_launcher, quoted_desktop_file);
+        json_builder_add_string_value(b, cmd);
+        g_free(cmd);
+        g_free(quoted_desktop_file);
+        g_free(quoted_launcher);
+    } else {
+        char *clean_exec = strip_desktop_exec_field_codes(session->exec);
+        json_builder_add_string_value(b, clean_exec);
+        g_free(clean_exec);
+    }
+
     json_builder_end_array(b);
+    greetd_add_session_env(b, session);
     greetd_send_object(b);
 }
 
